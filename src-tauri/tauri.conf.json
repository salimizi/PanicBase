{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PanicBase",
  "version": "0.2.0",
  "identifier": "com.panicbase.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1423",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PanicBase 0.2.0",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true,
        "maximizable": true,
        "maximized": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost; font-src 'self' data:;",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/libimobiledevice/**/*"
    ]
  }
}
