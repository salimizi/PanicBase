{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PanicBase",
  "version": "0.1.0",
  "identifier": "com.panicbase.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PanicBase",
        "width": 520,
        "height": 800,
        "minWidth": 520,
        "maxWidth": 520,
        "minHeight": 800,
        "maxHeight": 800,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
